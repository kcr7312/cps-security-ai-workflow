{
  "schema_version": "1.1.0",
  "rule_version": "1.1.0",
  "input_contract": {
    "required_any": [
      "finding_name",
      "protocol",
      "destination_port",
      "risk_tags"
    ],
    "optional_fields": [
      "source_zone",
      "destination_zone",
      "source_port",
      "session_state"
    ],
    "port_type": "integer_or_numeric_string",
    "risk_tags_type": "array_of_strings"
  },
  "normalization": {
    "unicode_form": "NFKC",
    "trim_whitespace": true,
    "collapse_internal_whitespace": true,
    "remove_trailing_candidate_word": true,
    "trailing_candidate_words": [
      "후보"
    ],
    "case_insensitive_finding_name": true,
    "case_insensitive_protocol": true,
    "case_insensitive_zone": true,
    "protocol_aliases": {
      "WS-DISCOVERY": "WSD",
      "WS_DISCOVERY": "WSD",
      "UPNP": "SSDP",
      "M-DNS": "MDNS",
      "MODBUS-TCP": "MODBUS/TCP"
    }
  },
  "evaluation_policy": {
    "sort_by": [
      "priority_desc",
      "file_order"
    ],
    "first_match_wins": true,
    "skip_disabled_rules": true,
    "catalog_search_metadata_used_for_match": false,
    "ambiguous_generic_findings": [
      "UDP 검토",
      "HTTP 검토",
      "SSL 검토",
      "Attempt 상태 통신"
    ],
    "ambiguous_generic_findings_action": "do_not_match_without_additional_rule_evidence"
  },
  "supported_operators": [
    "finding_name_in",
    "protocol_in",
    "destination_port_in",
    "source_port_in",
    "source_zone_in",
    "destination_zone_in",
    "session_state_in",
    "risk_tags_any",
    "all",
    "any"
  ],
